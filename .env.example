# ── Ingestion service ─────────────────────────────────────────────
# Kafka bootstrap servers. Local: localhost:9092. Prod: Event Hubs endpoint.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Topic template — {tenant_id} is substituted per tenant.
KAFKA_TOPIC_TEMPLATE=stripe.events.{tenant_id}
# Fallback topic when tenant cannot be resolved from the event.
KAFKA_DEFAULT_TOPIC=stripe.events.unknown

# Stripe webhook signing secret (Dashboard → Developers → Webhooks → Signing secret).
# whsec_... — required to verify incoming webhook signatures.
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Max age (seconds) of a webhook timestamp before it is rejected as a replay.
STRIPE_WEBHOOK_TOLERANCE=300

# Service
LOG_LEVEL=INFO
ENV=local

# ── Datastores (docker-compose) ──────────────────────────────────
POSTGRES_USER=foresight
POSTGRES_PASSWORD=foresight
POSTGRES_DB=foresight
REDIS_URL=redis://localhost:6379/0
