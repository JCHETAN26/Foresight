# Copy to agent/.env (gitignored) and fill in your key to run the agent live.
# The real Claude reasoning node reads ANTHROPIC_API_KEY from the environment;
# agent/.env is loaded by foresight_agent.run at startup.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: post alerts to Slack (leave unset to just print the formatted alert).
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
